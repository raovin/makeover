    "controlStyles[0].styles[0]": "Width=Auto",
    "controlStyles[0].styles[1]": "HorizontalAlignment=Center",
    "controlStyles[0].styles[2]": "VerticalAlignment=Bottom",
    "controlStyles[0].styles[3]": "Margin=24,5,24,3",
    "controlStyles[1].target": "Taskbar.TaskbarFrame > Grid#RootGrid",
    "controlStyles[1].styles[0]": "Background:=<LinearGradientBrush StartPoint=\"0,0\" EndPoint=\"0,1\"><GradientStop Color=\"#FF242A32\" Offset=\"0\"/><GradientStop Color=\"#FF171B21\" Offset=\"0.55\"/><GradientStop Color=\"#FF11151A\" Offset=\"1\"/></LinearGradientBrush>",
    "controlStyles[1].styles[1]": "Padding=12,2,12,1",
    "controlStyles[1].styles[2]": "CornerRadius=14",
