    "controlStyles[5].styles[6]": "Background@ActivePointerOver:=<SolidColorBrush Color=\"#2EFFFFFF\" />",
    "controlStyles[5].styles[7]": "Background@InactivePressed:=<SolidColorBrush Color=\"#30FFFFFF\" />",
