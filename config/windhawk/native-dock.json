    "controlStyles[12].target": "Taskbar.TaskListLabeledButtonPanel#IconPanel > Taskbar.Badge",
    "controlStyles[12].styles[0]": "RenderTransformOrigin=1,0",
    "controlStyles[12].styles[1]": "RenderTransform:=<ScaleTransform ScaleX=\"0.76\" ScaleY=\"0.76\" />",
