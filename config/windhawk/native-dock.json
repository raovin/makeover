{
  "modId": "windows-11-taskbar-styler",
  "version": "1.7",
  "sourceUrl": "https://mods.windhawk.net/mods/windows-11-taskbar-styler.wh.cpp",
  "binaryUrl": "https://mods.windhawk.net/mods/windows-11-taskbar-styler/1.7_64.dll",
  "binarySha256": "5A2FD32F82AE1732C5478BC7BF018A36B4C8962051FEA6F391190A0244499C52",
  "include": "explorer.exe",
  "architecture": "x86-64",
  "settings": {
    "theme": "DockLike",
    "xamlDiagnosticsHandling": "allow",
    "controlStyles[0].target": "Taskbar.TaskbarFrame",
    "controlStyles[0].styles[0]": "Width=Auto",
    "controlStyles[0].styles[1]": "HorizontalAlignment=Center",
    "controlStyles[0].styles[2]": "VerticalAlignment=Bottom",
    "controlStyles[0].styles[3]": "Margin=120,7,120,3",
    "controlStyles[1].target": "Taskbar.TaskbarFrame > Grid#RootGrid",
    "controlStyles[1].styles[0]": "Background:=<SolidColorBrush Color=\"#FF171A1F\" />",
    "controlStyles[1].styles[1]": "Padding=12,2,12,0",
    "controlStyles[1].styles[2]": "CornerRadius=15",
    "controlStyles[1].styles[3]": "BorderBrush:=<SolidColorBrush Color=\"#FF4F5B67\" />",
    "controlStyles[1].styles[4]": "BorderThickness=1",
    "controlStyles[1].styles[5]": "BackgroundSizing=InnerBorderEdge",
    "controlStyles[2].target": "Grid#SystemTrayFrameGrid",
    "controlStyles[2].styles[0]": "Visibility=Collapsed",
    "controlStyles[3].target": "SystemTray.Stack#ShowDesktopStack",
    "controlStyles[3].styles[0]": "Visibility=Collapsed",
    "controlStyles[4].target": "Taskbar.TaskbarFrame > Grid#RootGrid > Taskbar.TaskbarBackground > Grid > Rectangle#BackgroundFill",
    "controlStyles[4].styles[0]": "Visibility=Collapsed",
    "controlStyles[5].target": "Taskbar.TaskListButtonPanel@CommonStates > Border#BackgroundElement",
    "controlStyles[5].styles[0]": "CornerRadius=10",
    "controlStyles[5].styles[1]": "Margin=2,3,2,3",
    "controlStyles[5].styles[2]": "Background@InactiveNormal=Transparent",
    "controlStyles[5].styles[3]": "Background@ActiveNormal:=<SolidColorBrush Color=\"#2638424D\" />",
    "controlStyles[5].styles[4]": "Background@InactivePointerOver:=<SolidColorBrush Color=\"#20FFFFFF\" />",
    "controlStyles[5].styles[5]": "Background@ActivePointerOver:=<SolidColorBrush Color=\"#304D5966\" />",
    "controlStyles[5].styles[6]": "Background@InactivePressed:=<SolidColorBrush Color=\"#2AFFFFFF\" />",
    "controlStyles[5].styles[7]": "Background@ActivePressed:=<SolidColorBrush Color=\"#38556370\" />",
    "controlStyles[6].target": "Taskbar.ExperienceToggleButton#LaunchListButton[AutomationProperties.Name=Start]",
    "controlStyles[6].styles[0]": "Visibility=Collapsed",
    "controlStyles[7].target": "Taskbar.SearchBoxButton",
    "controlStyles[7].styles[0]": "Visibility=Collapsed",
    "controlStyles[8].target": "Taskbar.AugmentedEntryPointButton#AugmentedEntryPointButton[AutomationProperties.AutomationId=WidgetsButton]",
    "controlStyles[8].styles[0]": "Visibility=Collapsed",
    "controlStyles[9].target": "Taskbar.TaskListLabeledButtonPanel@RunningIndicatorStates > Rectangle#RunningIndicator",
    "controlStyles[9].styles[0]": "Fill=#8299A6B4",
    "controlStyles[9].styles[1]": "Fill@ActiveRunningIndicator=#FFEAF0F6",
    "controlStyles[9].styles[2]": "Fill@RequestingAttentionRunningIndicator=#FFF0A55A",
    "controlStyles[9].styles[3]": "Height=2",
    "controlStyles[9].styles[4]": "Width=8",
    "controlStyles[9].styles[5]": "Width@ActiveRunningIndicator=13",
    "controlStyles[9].styles[6]": "RadiusX=2",
    "controlStyles[9].styles[7]": "RadiusY=2",
    "controlStyles[9].styles[8]": "Margin=0,0,0,2",
    "controlStyles[10].target": "Taskbar.TaskListLabeledButtonPanel#IconPanel > Image#Icon",
    "controlStyles[10].styles[0]": "RenderTransform:=<TranslateTransform Y=\"1\" />",
    "controlStyles[11].target": "Taskbar.TaskListLabeledButtonPanel#IconPanel > Image#OverlayIcon",
    "controlStyles[11].styles[0]": "RenderTransform:=<TranslateTransform Y=\"1\" />",
    "controlStyles[12].target": "Taskbar.TaskListLabeledButtonPanel#IconPanel > Taskbar.Badge",
    "controlStyles[12].styles[0]": "RenderTransform:=<TranslateTransform Y=\"1\" />"
  }
}
